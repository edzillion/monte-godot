; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Monte Godot"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Utils="*res://src/utils/utils.gd"
Logger="*res://src/utils/logger.gd"
GDStats="*res://addons/gdstats - godot v3/gdstats.gd"
ProbabilityServer="*res://addons/gdstats - godot v3/gdstats.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/easy_charts/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/gdstats - godot v3/plugin.cfg", "res://addons/numdot/plugin.cfg", "res://addons/picklegd/plugin.cfg")

[gdunit4]

settings/test/test_lookup_folder="tests"
ui/toolbar/run_overall=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
